# Enable RewriteEngine
RewriteEngine On

# Force HTTPS (optional but recommended)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Allow access to _next directory (fixes 403 Forbidden errors)
<IfModule mod_authz_core.c>
    <Directory "_next">
        Require all granted
    </Directory>
    <Directory "images">
        Require all granted
    </Directory>
</IfModule>

# For older Apache versions
<IfModule !mod_authz_core.c>
    <Directory "_next">
        Order allow,deny
        Allow from all
    </Directory>
    <Directory "images">
        Order allow,deny
        Allow from all
    </Directory>
</IfModule>

# Disable mod_security for static assets (if causing 403 errors)
<IfModule mod_security.c>
    SecFilterEngine Off
    SecFilterScanPOST Off
</IfModule>

# Proper MIME types for static assets
<IfModule mod_mime.c>
    # JavaScript
    AddType application/javascript js mjs
    AddType text/javascript js mjs
    
    # CSS
    AddType text/css css
    
    # Images
    AddType image/svg+xml svg svgz
    AddType image/webp webp
    AddType image/avif avif
    
    # Fonts
    AddType font/woff woff
    AddType font/woff2 woff2
    AddType application/vnd.ms-fontobject eot
    AddType font/ttf ttf
    AddType font/otf otf
    
    # JSON
    AddType application/json json
    AddType application/manifest+json webmanifest
</IfModule>

# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Cache control for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # Enable XSS protection
    Header set X-XSS-Protection "1; mode=block"
    
    # Prevent clickjacking
    Header set X-Frame-Options "SAMEORIGIN"
    
    # Set proper CORS for fonts and assets
    <FilesMatch "\.(ttf|ttc|otf|eot|woff|woff2|font.css|css|js)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>

# Handle routing for Next.js static export
# Redirect all requests to existing files/directories or to index.html
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Don't rewrite files or directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # Handle trailing slashes - redirect to version with trailing slash
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_URI} !(.*)/$
    RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]+$
    RewriteRule ^(.*)$ $1/ [L,R=301]
    
    # Serve index.html for directory requests
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(.*)$ $1index.html [L]
    
    # Handle 404 errors
    ErrorDocument 404 /404.html
</IfModule>

# Prevent directory browsing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
